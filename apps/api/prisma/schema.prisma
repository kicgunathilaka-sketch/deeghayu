generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  PRESIDENT
  VICE_PRESIDENT
  SECRETARY
  TREASURER
  COMMITTEE_MEMBER
  MEMBER
}

enum MemberStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
  DECEASED
}

enum PaymentType {
  JOINING_FEE
  MONTHLY_FEE
  EVENT_PAYMENT
  DONATION
  CUSTOM
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
  PARTIAL
  WAIVED
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ONGOING
  COMPLETED
  CANCELLED
}

enum EventCategory {
  MONTHLY_MEETING
  SPECIAL_MEETING
  COMMUNITY_EVENT
  VOLUNTEER_EVENT
  RELIGIOUS_EVENT
  OTHER
}

enum NotificationType {
  EMAIL
  IN_APP
  BOTH
}

enum RsvpResponse {
  GOING
  NOT_GOING
  MAYBE
}

// ─────────────────────────────────────────────
// USERS & MEMBERS
// ─────────────────────────────────────────────

model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  passwordHash       String
  role               Role           @default(MEMBER)
  isEmailVerified    Boolean        @default(false)
  emailVerifyToken   String?
  resetPasswordToken String?
  resetTokenExpiry   DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  member             Member?
  refreshTokens      RefreshToken[]
  notifications      Notification[]
  auditLogs          AuditLog[]

  @@index([email])
  @@map("users")
}

model Member {
  id               String       @id @default(cuid())
  userId           String       @unique
  membershipId     String       @unique
  fullName         String
  nic              String       @unique
  address          String
  phone            String
  profilePhoto     String?
  dateJoined       DateTime     @default(now())
  dateOfBirth      DateTime?
  occupation       String?
  status           MemberStatus @default(PENDING)
  qrCodeUrl        String?
  emergencyContact Json?
  familyDetails    Json?
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments         Payment[]
  attendances      Attendance[]
  committeeRoles   CommitteeRole[]
  rsvps            EventRsvp[]

  @@index([membershipId])
  @@index([nic])
  @@index([status])
  @@map("members")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────

model Payment {
  id          String        @id @default(cuid())
  memberId    String
  type        PaymentType
  status      PaymentStatus @default(PENDING)
  amount      Decimal       @db.Decimal(10, 2)
  paidAmount  Decimal       @db.Decimal(10, 2) @default(0)
  dueDate     DateTime?
  paidAt      DateTime?
  month       Int?
  year        Int?
  description String?
  receiptUrl  String?
  recordedBy  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  member      Member        @relation(fields: [memberId], references: [id])

  @@index([memberId])
  @@index([status])
  @@index([type])
  @@index([year, month])
  @@map("payments")
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Decimal  @db.Decimal(10, 2)
  category    String
  description String?
  receiptUrl  String?
  date        DateTime
  recordedBy  String
  year        Int
  month       Int
  createdAt   DateTime @default(now())

  @@index([year, month])
  @@map("expenses")
}

// ─────────────────────────────────────────────
// EVENTS & ATTENDANCE
// ─────────────────────────────────────────────

model Event {
  id           String        @id @default(cuid())
  title        String
  description  String?
  category     EventCategory
  status       EventStatus   @default(DRAFT)
  location     String?
  startTime    DateTime
  endTime      DateTime
  qrCode       String?
  qrExpiresAt  DateTime?
  maxAttendees Int?
  requiresRsvp Boolean       @default(false)
  requiresFee  Boolean       @default(false)
  feeAmount    Decimal?      @db.Decimal(10, 2)
  coverImage   String?
  createdBy    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  attendances  Attendance[]
  rsvps        EventRsvp[]
  gallery      EventGallery[]

  @@index([status])
  @@index([startTime])
  @@map("events")
}

model Attendance {
  id          String           @id @default(cuid())
  eventId     String
  memberId    String
  status      AttendanceStatus @default(PRESENT)
  checkedInAt DateTime         @default(now())
  isLate      Boolean          @default(false)
  deviceInfo  String?

  event       Event            @relation(fields: [eventId], references: [id])
  member      Member           @relation(fields: [memberId], references: [id])

  @@unique([eventId, memberId])
  @@index([eventId])
  @@index([memberId])
  @@map("attendances")
}

model EventRsvp {
  id        String       @id @default(cuid())
  eventId   String
  memberId  String
  response  RsvpResponse
  createdAt DateTime     @default(now())

  event     Event        @relation(fields: [eventId], references: [id])
  member    Member       @relation(fields: [memberId], references: [id])

  @@unique([eventId, memberId])
  @@map("event_rsvps")
}

model EventGallery {
  id         String   @id @default(cuid())
  eventId    String
  imageUrl   String
  caption    String?
  uploadedBy String
  createdAt  DateTime @default(now())

  event      Event    @relation(fields: [eventId], references: [id])

  @@map("event_gallery")
}

// ─────────────────────────────────────────────
// COMMITTEE PANEL
// ─────────────────────────────────────────────

model CommitteePanel {
  id        String          @id @default(cuid())
  year      Int             @unique
  isActive  Boolean         @default(false)
  notes     String?
  createdAt DateTime        @default(now())

  roles     CommitteeRole[]

  @@map("committee_panels")
}

model CommitteeRole {
  id        String         @id @default(cuid())
  panelId   String
  memberId  String
  role      Role
  startDate DateTime
  endDate   DateTime?
  notes     String?

  panel     CommitteePanel @relation(fields: [panelId], references: [id])
  member    Member         @relation(fields: [memberId], references: [id])

  @@unique([panelId, memberId, role])
  @@index([panelId])
  @@index([memberId])
  @@map("committee_roles")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS & AUDIT
// ─────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  body      String
  type      NotificationType @default(IN_APP)
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
